# WCA Scorecard Auto-Entry - Environment Variables

# Backend Port
PORT=5000

# Feature Toggles (true/false)
OPENAI_ENABLED=true
WCA_LIVE_ENABLED=true

# WCA Developer Portal OAuth Client ID
WCA_CLIENT_ID=your_wca_client_id_here

# OpenAI API Key (requires access to gpt-4o vision model)
OPENAI_API_KEY=your_openai_api_key_here

# WCA Live Session Token (Bearer token for authorization)
WCA_BEARER_TOKEN=your_wca_bearer_token_here
